{
  "name": "@nftm/root",
  "version": "0.1.0",
  "private": true,
  "description": "FreedomFi NFT Marketplace monorepo",
  "license": "MIT",
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm -F @nftm/db migrate",
    "db:seed": "pnpm -F @nftm/db seed",
    "contracts:test": "pnpm -F @nftm/contracts test",
    "contracts:build": "pnpm -F @nftm/contracts build",
    "compose:up": "docker compose -f infra/docker-compose.yml --env-file .env up -d",
    "compose:down": "docker compose -f infra/docker-compose.yml --env-file .env down",
    "compose:logs": "docker compose -f infra/docker-compose.yml --env-file .env logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
