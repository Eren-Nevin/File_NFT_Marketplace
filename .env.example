# ─────────────────────────────────────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
TRUST_PROXY=1

# Public origins (used for SIWE statement + absolute URLs)
DAPP_PUBLIC_ORIGIN=https://nft-marketplace.projects.erennevin.xyz
ADMIN_PUBLIC_ORIGIN=https://nft-marketplace-admin.projects.erennevin.xyz

# Internal (compose-network) API URL — used by SvelteKit servers
API_INTERNAL_URL=http://api:8080

# ─────────────────────────────────────────────────────────────────────────────
# Postgres / Redis
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=nftm
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nftm
# Keep in sync with POSTGRES_PASSWORD above.
DATABASE_URL=postgres://nftm:change-me@postgres:5432/nftm
REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────────────────────────────────────
# Chain config — defaults target Base mainnet (8453)
# ─────────────────────────────────────────────────────────────────────────────
# 8453 = Base mainnet, 84532 = Base Sepolia, 31337 = anvil/dev
CHAIN_ID=8453

# REQUIRED for mainnet. Get one from Alchemy / QuickNode / Coinbase Developer
# Platform / Infura. Free tiers are fine for V1 traffic.
BASE_RPC_URL=

# Optional — only needed if you also want to point compose at Sepolia or anvil.
BASE_SEPOLIA_RPC_URL=
ANVIL_RPC_URL=http://anvil:8545

# USDC addresses (do not change unless the canonical contract changes):
#   Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
#   Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Deployed contracts. Fill these in after running `pnpm -F @nftm/contracts
# deploy:base`; addresses are also written to packages/contracts/deployments/8453.json.
FACTORY_ADDRESS=
MARKETPLACE_ADDRESS=
NFT_COLLECTION_IMPLEMENTATION_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# Wallets / keys
# ─────────────────────────────────────────────────────────────────────────────
# Bootstrapped into the DB on first migrate; also DEFAULT_ADMIN_ROLE on factory
# + marketplace once deployed.
INITIAL_SUPER_ADMIN_ADDRESS=0xbc78c10F2ebB49e086DEb4B05C4193782FF93109

# Hot key that signs EIP-712 lazy-mint vouchers; holds MINTER_ROLE on each
# deployed NFTCollection. Recommended: a separate, rotatable EOA so a leak
# here doesn't compromise the super-admin wallet. V1 may set this equal to
# SUPER_ADMIN_PRIVATE_KEY/INITIAL_SUPER_ADMIN_ADDRESS for simplicity —
# rotate later via `grantRole(MINTER_ROLE, new) + revokeRole(MINTER_ROLE, old)`.
VOUCHER_SIGNER_PRIVATE_KEY=
VOUCHER_SIGNER_ADDRESS=

# Deployer key — used by `forge script script/Deploy.s.sol` only.
# Must correspond to INITIAL_SUPER_ADMIN_ADDRESS; gets DEFAULT_ADMIN_ROLE on
# the factory and marketplace.
SUPER_ADMIN_PRIVATE_KEY=

# Receives primary sales (100%) + 2.5% secondary platform fee. May be the
# super-admin EOA, or a separate cold/treasury wallet you sweep into.
TREASURY_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────────────────────────────────────
# Rotate yearly. >=32 random bytes; generate with: openssl rand -hex 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
# Cookie domain that covers both subdomains; leave blank to scope per-host
SESSION_COOKIE_DOMAIN=

# ─────────────────────────────────────────────────────────────────────────────
# IPFS (Pinata)
# ─────────────────────────────────────────────────────────────────────────────
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ─────────────────────────────────────────────────────────────────────────────
# Basescan (Etherscan-compatible) — used by `forge script --verify`
# ─────────────────────────────────────────────────────────────────────────────
# Get one at https://basescan.org/myapikey
ETHERSCAN_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Limits
# ─────────────────────────────────────────────────────────────────────────────
MEDIA_MAX_BYTES=104857600   # 100 MB
BODY_SIZE_LIMIT=104857600   # 100 MB — SvelteKit adapter-node body cap; match MEDIA_MAX_BYTES
